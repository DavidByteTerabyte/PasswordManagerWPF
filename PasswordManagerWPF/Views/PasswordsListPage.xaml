<Page x:Class="PasswordManagerWPF.Views.PasswordsListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="PasswordsListPage">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Ваші збережені паролі" Style="{StaticResource HeaderTextStyle}" HorizontalAlignment="Left" Grid.Row="0"/>

        <!-- Панель ПОШУКУ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Label Content="Пошук сайту:" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBox Name="txtSearch" Width="250" Height="30" Margin="10,0,0,0" TextChanged="txtSearch_TextChanged" VerticalContentAlignment="Center"/>
        </StackPanel>

        <!-- Розумна таблиця -->
        <DataGrid Name="dgPasswords" Grid.Row="2" ItemsSource="{Binding}" AutoGenerateColumns="False" IsReadOnly="True" Background="White" RowHeight="35">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Сайт / Сервіс" Binding="{Binding Site}" Width="*"/>
                <DataGridTextColumn Header="Логін / Email" Binding="{Binding Login}" Width="*"/>

                <!-- Замість того щоб показувати пароль, покажемо зірочки -->
                <DataGridTextColumn Header="Пароль" Binding="{Binding Password}" Width="*"/>

                <!-- Кнопка копіювати -->
                <DataGridTemplateColumn Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Копіювати" Background="{StaticResource AccentColor}" Foreground="White" BorderThickness="0" Margin="2" Click="btnCopy_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Кнопка видалити -->
                <DataGridTemplateColumn Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Видалити" Background="{StaticResource DangerColor}" Foreground="White" BorderThickness="0" Margin="2" Click="btnDelete_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
<Window x:Class="PasswordManagerWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Password Manager - Локальний Сейф" 
        Height="450" Width="800"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen">

    <!-- Головна сітка (Grid) розбиває вікно на 2 колонки: Меню (ліворуч) і Контент (праворуч) -->
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- ТУТ СТАВИМО Auto замість 200 -->
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- А ТУТ ДОДАЄМО Width="200" -->
        <Border x:Name="LeftMenuPanel" Grid.Column="0" Width="200" Background="#2C3E50" Visibility="Collapsed">
            <StackPanel Margin="10,20,10,10">
                <TextBlock Text="МЕНЮ" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <Button Content="Мої паролі" Style="{StaticResource MenuBtnStyle}" Click="btnShowList_Click"/>
                <Button Content="Додати новий" Style="{StaticResource MenuBtnStyle}" Click="btnAdd_Click"/>
                <Separator Height="150" Visibility="Hidden"/>
                <Button Content="Вийти" Style="{StaticResource MenuBtnStyle}" Background="{StaticResource DangerColor}" Click="btnExit_Click"/>

            </StackPanel>
        </Border>

        <!-- Основна область контенту (Frame), де будуть перемикатися сторінки -->
        <Frame Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Background="#ECF0F1"/>

    </Grid>
</Window>
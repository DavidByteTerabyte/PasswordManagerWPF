<Window x:Class="PasswordManagerWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Password Manager - Локальний Сейф" 
        Height="450" Width="800"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen">

    <!-- Головна сітка (Grid) розбиває вікно на 2 колонки: Меню (ліворуч) і Контент (праворуч) -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <!-- Ширина меню -->
            <ColumnDefinition Width="*"/>
            <!-- Все інше місце під контент -->
        </Grid.ColumnDefinitions>

        <!-- Ліва панель (Меню) -->
        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Margin="10,20,10,10">
                <TextBlock Text="МЕНЮ" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                <Button Name="btnShowList" Content="Мої паролі" Height="40" Margin="0,0,0,10" Background="#34495E" Foreground="White" Click="btnShowList_Click"/>
                <Button Name="btnAdd" Content="Додати новий" Height="40" Margin="0,0,0,10" Background="#34495E" Foreground="White" Click="btnAdd_Click"/>

                <!-- Пустий простір, щоб відсунути кнопку виходу вниз -->
                <Separator Height="150" Visibility="Hidden"/>

                <Button Name="btnExit" Content="Вийти / Заблокувати" Height="40" Background="#E74C3C" Foreground="White" Click="btnExit_Click"/>
            </StackPanel>
        </Border>

        <!-- Основна область контенту (Frame), де будуть перемикатися сторінки -->
        <Frame Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Background="#ECF0F1"/>

    </Grid>
</Window>